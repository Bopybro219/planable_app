# Canonical runtime environment. APP_ENV is preferred; FLASK_ENV is only a fallback for compatibility.
APP_ENV=development

# Core app security
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
SESSION_COOKIE_SECURE=false
SESSION_LIFETIME_SECONDS=1209600
LOG_LEVEL=INFO

# App host / proxy settings
SERVER_NAME=
TRUSTED_HOSTS=
PROXY_FIX_COUNT=0
PORT=5000

# Database
# Leave DATABASE_URL unset in local development to use the SQLite fallback.
DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
ADMIN_EMAILS=you@example.com

# Public product details
PUBLIC_CONTACT_PHONE=01604 289096

# Abuse protection / Turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Redis-backed rate limiting
REDIS_URL=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_FAIL_OPEN=true
PUBLIC_SEARCH_RATE_LIMIT=30
PUBLIC_SEARCH_RATE_LIMIT_WINDOW_SECONDS=3600
API_RATE_LIMIT_BURST=60
API_RATE_LIMIT_BURST_WINDOW_SECONDS=60
API_RATE_LIMIT_DAILY=1000
API_WRITE_RATE_LIMIT_BURST=30
API_WRITE_RATE_LIMIT_WINDOW_SECONDS=3600

# Upload / request limits
MAX_CONTENT_LENGTH=2097152
PROFILE_IMAGE_MAX_BYTES=2097152
PLACE_IMAGE_MAX_MB=2
PROFILE_IMAGE_UPLOAD_DIR=
PLACE_IMAGE_UPLOAD_DIR=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PAID_CONSUMER=
# Disabled early API pack checkout price IDs are kept here only for old environments.
# The app does not require these while API packs remain disabled.
STRIPE_PRICE_API_20=
STRIPE_PRICE_API_50=
STRIPE_PRICE_API_100=

# Email delivery
EMAIL_ENABLED=false
EMAIL_DEV_MODE=true
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=hello@example.com
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_TIMEOUT_SECONDS=5
SUPPORT_EMAIL=support@example.com

# Newsletter
NEWSLETTER_ENABLED=false

# Analytics
GA_MEASUREMENT_ID=
ENABLE_ANALYTICS_IN_DEV=false

# Advertising
ADSENSE_CLIENT_ID=
ADSENSE_ENABLED=false
ENABLE_ADS_IN_DEV=false
ADSENSE_SLOT_SEARCH_RESULTS=
ADSENSE_SLOT_PLACE_DETAIL=
ADSENSE_SLOT_FOOTER=
