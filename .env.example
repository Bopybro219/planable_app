SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
# Leave DATABASE_URL unset to use the local SQLite fallback in development.
DATABASE_URL=postgresql+psycopg2://planira_user:password@localhost:5432/planira
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# For local dev use: http://127.0.0.1:5000/auth/google/callback
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
ADMIN_EMAILS=you@example.com
PUBLIC_CONTACT_PHONE=01604 289096
APP_ENV=development
SESSION_COOKIE_SECURE=false
SESSION_LIFETIME_SECONDS=1209600
MAX_CONTENT_LENGTH=1048576
LOG_LEVEL=INFO
EMAIL_ENABLED=false
EMAIL_DEV_MODE=true
NEWSLETTER_ENABLED=false
GA_MEASUREMENT_ID=
ENABLE_ANALYTICS_IN_DEV=false
ADSENSE_CLIENT_ID=
ADSENSE_ENABLED=false
ENABLE_ADS_IN_DEV=false
ADSENSE_SLOT_SEARCH_RESULTS=
ADSENSE_SLOT_PLACE_DETAIL=
ADSENSE_SLOT_FOOTER=
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=hello@example.com
MAIL_USE_TLS=true
MAIL_USE_SSL=false
SUPPORT_EMAIL=support@example.com
# Optional local API example key:
PLANIRA_API_KEY=plnr_replace_me
# Production examples:
# SERVER_NAME=your-domain.com
# TRUSTED_HOSTS=your-domain.com,www.your-domain.com
# PROXY_FIX_COUNT=1
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PAID_CONSUMER=price_...
# STRIPE_PRICE_API_20=price_...
# STRIPE_PRICE_API_50=price_...
# STRIPE_PRICE_API_100=price_...
